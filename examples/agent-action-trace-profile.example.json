{
  "apiVersion": "agent-standards.socioprophet.org/v0.1",
  "kind": "AgentActionTraceProfile",
  "metadata": {
    "name": "bootstrap-agent-action-trace-profile",
    "profileVersion": "0.1.0",
    "description": "Example runtime-facing profile consuming the Action Ontology without owning the ontology source."
  },
  "spec": {
    "ontologyRef": "github://SocioProphet/ontogenesis/Middle/action-ontology.ttl",
    "standardsRef": "github://SocioProphet/socioprophet-standards-storage/docs/standards/138-action-ontology-bootstrap-temp-landing.md",
    "agent": {
      "subjectRef": "agent://example/bootstrap-agent",
      "runtimeRole": "governed-runtime-agent"
    },
    "capabilities": [
      "observe",
      "consume",
      "executeTask",
      "writeTrace"
    ],
    "tracePatterns": [
      "ContractNet",
      "PubSub",
      "ContractNetPubSubBridge"
    ],
    "evidence": {
      "requiresPolicyRef": true,
      "requiresReceiptRef": true,
      "receiptKinds": [
        "ActionTraceReceipt",
        "PolicyDecisionReceipt"
      ]
    }
  }
}
