{
  "$schema": "https://standards.socioprophet.org/schemas/personal-intelligence-cell-fixtures.schema.json",
  "title": "Personal Intelligence Cell Watch Pattern Fixtures",
  "description": "Concrete conformance scenarios for typed watch patterns, source ingestion, signal extraction, scoring, policy, feed emission, feedback, and archive readiness.",
  "fixtures": [
    {
      "id": "fixture.weather.alert.v1",
      "domain": "weather_alert",
      "source": {
        "kind": "rss",
        "uri": "fixture://weather/rss"
      },
      "watch_pattern": {
        "pattern_kind": "typed_template",
        "raw_expression": "$location severe weather alert $time",
        "variables": [
          { "name": "location", "type": "location", "required": true },
          { "name": "time", "type": "time", "required": false }
        ]
      },
      "input": "Bucks County severe weather alert tonight after 8 PM.",
      "expected_extractions": {
        "location": "Bucks County",
        "time": "tonight after 8 PM"
      },
      "expected_signal": {
        "min_relevance_score": 0.7,
        "requires_policy_gate": true,
        "requires_feed_item": true
      }
    },
    {
      "id": "fixture.real_estate.listing.v1",
      "domain": "real_estate_listing",
      "source": {
        "kind": "web",
        "uri": "fixture://real-estate/listings"
      },
      "watch_pattern": {
        "pattern_kind": "typed_template",
        "raw_expression": "$property_type in $location under $money",
        "variables": [
          { "name": "property_type", "type": "entity", "required": true },
          { "name": "location", "type": "location", "required": true },
          { "name": "money", "type": "money", "required": true }
        ]
      },
      "input": "Townhouse in Doylestown under $450,000 with garage and walkable center access.",
