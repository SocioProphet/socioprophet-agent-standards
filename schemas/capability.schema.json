{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.dev/schemas/capability.schema.json",
  "title": "CapabilityDefinition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version",
    "description",
    "owners",
    "inputs",
    "outputs",
    "tests"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/port"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/port"
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Named test suites or checks that prove the capability."
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback": {
      "type": "string",
      "description": "Plain-language rollback semantics for this capability."
    },
    "areas": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Enduring operational areas that own or depend on this capability."
    }
  },
  "$defs": {
    "port": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "description"],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
