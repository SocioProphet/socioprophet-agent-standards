{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.dev/schemas/capability-manifest.schema.json",
  "title": "CapabilityManifestV0",
  "type": "object",
  "required": [
    "version",
    "node_id",
    "public_key",
    "roles",
    "transports",
    "path_templates",
    "issued_at",
    "signatures"
  ],
  "properties": {
    "version": { "const": "capability-manifest/v0" },
    "node_id": { "type": "string", "minLength": 16 },
    "public_key": { "type": "string" },
    "hostname": { "type": "string" },
    "roles": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "peer", "relay", "exit", "bridge", "introducer", "storage", "compute", "mix-gateway", "mix-node", "service"
        ]
      }
    },
    "transports": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "wireguard", "relay", "bluetooth", "wifi-direct", "tor-bridge", "obfs4-like", "quic", "tcp", "udp"
        ]
      }
    },
    "path_templates": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["P0-direct", "P1-relay", "P2-microcascade", "P3-onion", "P4-mix"]
      }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "jurisdiction": { "type": "string" },
        "operator": { "type": "string" },
        "asns": { "type": "array", "items": { "type": "integer" } },
        "not_before": { "type": "string", "format": "date-time" },
        "not_after": { "type": "string", "format": "date-time" },
        "max_clients": { "type": "integer", "minimum": 1 },
        "allow_full_tunnel": { "type": "boolean" },
        "allow_anonymous_ingress": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "issued_at": { "type": "string", "format": "date-time" },
    "revocation": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["active", "revoked", "suspended"] },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key_id", "algorithm", "signature"],
        "properties": {
          "key_id": { "type": "string" },
          "algorithm": { "type": "string" },
          "signature": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
